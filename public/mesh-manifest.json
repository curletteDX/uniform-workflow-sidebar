{
  "$schema": "https://uniform.app/schemas/mesh-manifest.json",
  "type": "workflow-sidebar",
  "displayName": "Workflow Sidebar",
  "description": "Visual workflow timeline with navigation controls for the Canvas editor",
  "version": "1.0.0",
  "locations": {
    "canvas": {
      "editorTools": {
        "composition": {
          "url": "/editor-tool",
          "displayName": "Workflow",
          "iconUrl": "/icons/workflow.svg"
        },
        "componentPattern": {
          "url": "/editor-tool",
          "displayName": "Workflow",
          "iconUrl": "/icons/workflow.svg"
        },
        "entry": {
          "url": "/editor-tool",
          "displayName": "Workflow",
          "iconUrl": "/icons/workflow.svg"
        },
        "entryPattern": {
          "url": "/editor-tool",
          "displayName": "Workflow",
          "iconUrl": "/icons/workflow.svg"
        }
      }
    }
  }
}
